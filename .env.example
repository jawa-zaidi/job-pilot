# Copy to .env and fill in
GROQ_API_KEY=
# Optional overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PORT=4310
# Network binding: the app binds to 127.0.0.1 (localhost only) by default.
# Opt in to LAN access (reachable by other devices on your network) with either:
# HOST=0.0.0.0
# JOBPILOT_LAN=1
# Later: APIFY_TOKEN= (LinkedIn scraping), SMTP creds (real email sending)
